# Anthropic (Claude) — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase (auth + DB)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe (subscriptions: Lite $4.99, Pro $9.99, Premium $25)
# Local: use pk_test_/sk_test_ and test price IDs. Production (Vercel): use pk_live_/sk_live_ and live price IDs.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_LITE_PRICE_ID=price_xxxxx
# STRIPE_PRO_PRICE_ID=price_xxxxx
# STRIPE_PREMIUM_PRICE_ID=price_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx  (Stripe CLI locally; Dashboard signing secret in production)
# NEXT_PUBLIC_APP_URL=http://localhost:3000  (optional; in production set to https://your-app.vercel.app for Stripe redirects)

# Site variant — **changing this in Vercel requires a new deployment** (NEXT_PUBLIC is baked at build).
# Set either name (next.config copies SITE_VARIANT → NEXT_PUBLIC for the client bundle):
#   default   = full product (humanizer in nav, detector-focused SEO & homepage)
#   portfolio = demo/resume mode: writing-suite homepage & nav; /humanize → /essay-writer;
#               /ai-check → /summarizer; Turnitin/humanize/detector help articles → /help;
#               help, pricing, login/signup, account, essay-writer use neutral copy.
# Aliases for portfolio: experimental | adjusted | alt
# NEXT_PUBLIC_SITE_VARIANT=portfolio
# SITE_VARIANT=portfolio

# Admin console (local only): set a secret and use it at /admin to view stats (users, Supabase, usage).
# ADMIN_SECRET=

# Grant premium access to this email without payment (e.g. owner account). Leave empty to disable.
ADMIN_PREMIUM_EMAIL=bypassrai@gmail.com
